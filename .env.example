# Copy to .env and fill in. .env is gitignored.

# --- Required: embeddings + (default) generation ---
OPENAI_API_KEY=sk-...

# --- Generation provider: "openai" (default, spec) or "anthropic" ---
GENERATION_PROVIDER=openai
# OPENAI_CHAT_MODEL=gpt-4o-mini
# ANTHROPIC_API_KEY=sk-ant-...        # only if GENERATION_PROVIDER=anthropic
# ANTHROPIC_CHAT_MODEL=claude-haiku-4-5-20251001

# --- Retrieval hyperparameters (experiment surface) ---
# CHUNK_SIZE=1000
# CHUNK_OVERLAP=200
# TOP_K=3

# --- Langfuse tracing (optional; pipeline runs without it) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --- Tier A CI gate ---
# FAITHFULNESS_FLOOR=0.70
